{
  "type": "object",
  "required": ["phases"],
  "additionalProperties": false,
  "properties": {
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content", "checks", "estimated_time_minutes", "concept_tags"],
        "additionalProperties": false,
        "properties": {
          "content": {
            "type": "string"
          },
          "estimated_time_minutes": {
            "type": "integer"
          },
          "concept_tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "prerequisites": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["question", "options", "difficulty"],
              "additionalProperties": false,
              "properties": {
                "question": { "type": "string" },
                "difficulty": { "type": "integer" },
                "options": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["key", "text", "correct"],
                    "additionalProperties": false,
                    "properties": {
                      "key": { "type": "string" },
                      "text": { "type": "string" },
                      "correct": { "type": "boolean" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
