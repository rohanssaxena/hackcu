{
  "type": "object",
  "required": ["topics"],
  "additionalProperties": false,
  "properties": {
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "phases"],
        "additionalProperties": false,
        "properties": {
          "topic": { "type": "string" },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "content", "estimated_time_minutes", "checks"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string" },
                "content": { "type": "string" },
                "estimated_time_minutes": { "type": "integer" },
                "checks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["question", "difficulty", "options"],
                    "additionalProperties": false,
                    "properties": {
                      "question": { "type": "string" },
                      "difficulty": { "type": "integer" },
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["text", "correct", "explanation"],
                          "additionalProperties": false,
                          "properties": {
                            "text": { "type": "string" },
                            "correct": { "type": "boolean" },
                            "explanation": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
